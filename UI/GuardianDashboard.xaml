<UserControl x:Class="PropFirmGuardian.UI.GuardianDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:PropFirmGuardian.Models"
             Background="#FF0A0A0F"
             Foreground="White">
    <UserControl.Resources>
        <Style x:Key="DarkButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#FF252525" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#FF3D3D3D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="ToolTipService.ShowDuration" Value="12000" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF333333" />
                    <Setter Property="BorderBrush" Value="#FF00FFAA" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF1F3B2E" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource DarkButtonStyle}">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="GridTextBlockStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="Padding" Value="2,0" />
        </Style>

        <Style x:Key="EmergencyButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource DarkButtonStyle}">
            <Setter Property="Background" Value="#FFB91C1C" />
            <Setter Property="BorderBrush" Value="#FFEF4444" />
            <Setter Property="Padding" Value="14,7" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFDC2626" />
                    <Setter Property="BorderBrush" Value="#FFFF7373" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF991B1B" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Background" Value="#FF252525" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#FF3D3D3D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="ToolTip" Value="Toggle shadow mode for this account." />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#FF00FFAA" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#FF1F3B2E" />
                    <Setter Property="BorderBrush" Value="#FF00FFAA" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#FF202020" />
            <Setter Property="Foreground" Value="#FFE8E8E8" />
            <Setter Property="BorderBrush" Value="#FF333333" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="40" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#FF1F1F1F" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF244837" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="#FF171717" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="MinHeight" Value="52" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:AccountState.Active}">
                    <Setter Property="BorderBrush" Value="#FF00FFAA" />
                    <Setter Property="BorderThickness" Value="3,0,0,0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:AccountState.Warning}">
                    <Setter Property="Background" Value="#FF342515" />
                    <Setter Property="BorderBrush" Value="#FFFF6B35" />
                    <Setter Property="BorderThickness" Value="3,0,0,0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:AccountState.Flattening}">
                    <Setter Property="Background" Value="#FF3A1717" />
                    <Setter Property="BorderBrush" Value="#FFEF4444" />
                    <Setter Property="BorderThickness" Value="3,0,0,0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:AccountState.Locked}">
                    <Setter Property="Background" Value="#FF3A1717" />
                    <Setter Property="BorderBrush" Value="#FFEF4444" />
                    <Setter Property="BorderThickness" Value="3,0,0,0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:AccountState.NewsLocked}">
                    <Setter Property="Background" Value="#FF3A2412" />
                    <Setter Property="BorderBrush" Value="#FFFF6B35" />
                    <Setter Property="BorderThickness" Value="3,0,0,0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:AccountState.Disconnected}">
                    <Setter Property="Background" Value="#FF202020" />
                    <Setter Property="BorderBrush" Value="#FF808080" />
                    <Setter Property="BorderThickness" Value="3,0,0,0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#FF0A0A0F" MinWidth="1024" MinHeight="768">
        <Grid.RowDefinitions>
            <RowDefinition Height="58" />
            <RowDefinition Height="138" />
            <RowDefinition Height="*" />
            <RowDefinition Height="34" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#FF0A0A0F" Margin="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <Ellipse Width="20" Height="20" Fill="#FF00D4AA" Margin="0,0,10,0" />
                <TextBlock Text="PROP FIRM GUARDIAN"
                           Foreground="#FFFFFFFF"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
                <TextBlock Text="v3 Co-Pilot"
                           Foreground="#FF00D4AA"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
                <Border Background="#FF252525"
                        BorderBrush="#FF3D3D3D"
                        BorderThickness="1"
                        Padding="10,4"
                        Margin="18,0,0,0">
                    <TextBlock x:Name="NewsBannerText"
                               Text="News: Clear"
                               Foreground="#FFBDBDBD"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="NewsAffectedAccountsText"
                           Text=""
                           Foreground="#FFFF6B35"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0" />
                <Border x:Name="RecoveryAlertBorder"
                        Visibility="Collapsed"
                        Background="#FF7F1D1D"
                        BorderBrush="#FFEF4444"
                        BorderThickness="1"
                        Padding="10,4"
                        Margin="10,0,0,0">
                    <TextBlock x:Name="RecoveryAlertText"
                               Text=""
                               Foreground="White"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="12,0,16,0">
                <Button Content="Add Active Accounts"
                        Style="{StaticResource DarkButtonStyle}"
                        MinWidth="148"
                        Margin="0,0,10,0"
                        ToolTip="Add connected NinjaTrader accounts back into monitoring."
                        Click="AddActiveAccounts_Click" />
                <Button Content="Emergency Flatten All"
                        Style="{StaticResource EmergencyButtonStyle}"
                        MinWidth="178"
                        ToolTip="Cancel working orders and flatten all eligible monitored accounts."
                        Click="EmergencyFlattenAll_Click" />
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="4" Margin="16,12,16,14">
            <Border Background="#FF1A1A24" BorderBrush="#FF2A2A3A" BorderThickness="1" Margin="0,0,8,0" Padding="14">
                <StackPanel>
                    <TextBlock Text="PASS PROBABILITY" Foreground="#FF8A8A9A" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock x:Name="PassProbabilityText" Text="50%" Foreground="#FF00D4AA" FontSize="30" FontWeight="Bold" Margin="0,8,0,0" />
                    <TextBlock x:Name="PassProbabilityMessageText"
                               Text="Select an account to view trajectory."
                               Foreground="#FF8A8A9A"
                               FontSize="11"
                               LineHeight="15"
                               MaxHeight="34"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
            <Border Background="#FF1A1A24" BorderBrush="#FF2A2A3A" BorderThickness="1" Margin="0,0,8,0" Padding="14">
                <StackPanel>
                    <TextBlock Text="TODAY'S STATS" Foreground="#FF8A8A9A" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock x:Name="TodayTradesText" Text="Trades: 0/10" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <TextBlock x:Name="ActiveGuardsText"
                               Text="No active guards"
                               Foreground="#FF8A8A9A"
                               FontSize="11"
                               LineHeight="15"
                               MaxHeight="34"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
            <Border Background="#FF1A1A24" BorderBrush="#FF2A2A3A" BorderThickness="1" Margin="0,0,8,0" Padding="14">
                <StackPanel>
                    <TextBlock Text="PORTFOLIO HEAT" Foreground="#FF8A8A9A" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock Text="Monitoring active" Foreground="#FF00D4AA" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <TextBlock Text="Per-account controls enabled" Foreground="#FF8A8A9A" FontSize="12" />
                </StackPanel>
            </Border>
            <Border Background="#FF1A1A24" BorderBrush="#FF2A2A3A" BorderThickness="1" Padding="14">
                <StackPanel>
                    <TextBlock Text="MARKET STATUS" Foreground="#FF8A8A9A" FontSize="11" FontWeight="SemiBold" />
                    <TextBlock x:Name="MarketStatusText" Text="News clear" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <TextBlock Text="Time guards evaluated every minute" Foreground="#FF8A8A9A" FontSize="12" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2" Background="#FF121212" Margin="16,0,16,0" ClipToBounds="True">
            <DataGrid x:Name="AccountsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Background="#FF121212"
                      Foreground="White"
                      BorderBrush="#FF2E2E2E"
                      BorderThickness="0"
                      HorizontalGridLinesBrush="#FF282828"
                      RowBackground="#FF171717"
                      AlternatingRowBackground="#FF1E1E1E"
                      HorizontalContentAlignment="Stretch"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ColumnWidth="*"
                      RowHeight="52">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Account" Binding="{Binding AccountName}" Width="1.35*" MinWidth="116" ElementStyle="{StaticResource GridTextBlockStyle}" />
                    <DataGridTextColumn Header="Connection" Binding="{Binding ConnectionStatus}" Width="0.92*" MinWidth="82" ElementStyle="{StaticResource GridTextBlockStyle}" />
                    <DataGridTextColumn Header="Realized" Binding="{Binding RealizedPnL, StringFormat={}{0:C2}}" Width="0.82*" MinWidth="76" ElementStyle="{StaticResource GridTextBlockStyle}" />
                    <DataGridTextColumn Header="Unrealized" Binding="{Binding UnrealizedPnL, StringFormat={}{0:C2}}" Width="0.9*" MinWidth="82" ElementStyle="{StaticResource GridTextBlockStyle}" />
                    <DataGridTextColumn Header="Peak" Binding="{Binding PeakPnL, StringFormat={}{0:C2}}" Width="0.78*" MinWidth="74" ElementStyle="{StaticResource GridTextBlockStyle}" />
                    <DataGridTextColumn Header="Drawdown" Binding="{Binding DrawdownFromPeak, StringFormat={}{0:C2}}" Width="0.88*" MinWidth="82" ElementStyle="{StaticResource GridTextBlockStyle}" />
                    <DataGridTemplateColumn Header="Trades Today" Width="0.98*" MinWidth="104">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TradesTodayDisplay}" Foreground="White" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    <ProgressBar Minimum="0"
                                                 Maximum="100"
                                                 Height="4"
                                                 Margin="0,4,0,0"
                                                 Value="{Binding TradesTodayPercent, Mode=OneWay}"
                                                 Foreground="#FF00D4AA"
                                                 Background="#FF252530" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Status" Width="0.86*" MinWidth="94">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="9" Height="9" Fill="{Binding StatusColor}" Margin="0,0,7,0" />
                                    <TextBlock Text="{Binding StatusDisplay}" Foreground="{Binding StatusColor}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Actions" Width="164" MinWidth="164" MaxWidth="164">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="Settings"
                                            Grid.Column="0"
                                            Tag="{Binding}"
                                            ToolTip="Open account risk settings."
                                            Style="{StaticResource CompactButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            Click="Settings_Click" />
                                    <Button Content="Remove"
                                            Grid.Column="2"
                                            Tag="{Binding}"
                                            ToolTip="Remove this account from monitoring. The NinjaTrader account is not deleted."
                                            Style="{StaticResource CompactButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            Click="RemoveAccount_Click" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border x:Name="NoAccountsOverlay"
                    Background="#DD121212"
                    BorderBrush="#FF3D3D3D"
                    BorderThickness="1"
                    Padding="18"
                    Width="520"
                    MaxWidth="700"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Visible">
                <StackPanel>
                    <TextBlock Text="No accounts are currently monitored."
                               Foreground="#FFFF6B35"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />
                    <TextBlock Text="Connect an account in NinjaTrader to begin monitoring."
                               Foreground="#FFDADADA"
                               FontSize="13"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border x:Name="SettingsOverlay"
                    Visibility="Collapsed"
                    HorizontalAlignment="Right"
                    Width="460"
                    Background="#FF1B1B1B"
                    BorderBrush="#FF3D3D3D"
                    BorderThickness="1,0,0,0">
                <ContentControl x:Name="SettingsContentHost" />
            </Border>
        </Grid>

        <DockPanel Grid.Row="3" Background="#FF0A0A0F" LastChildFill="True">
            <TextBlock x:Name="EngineStatusText"
                       Text="Status: Engine starting"
                       Foreground="#FF00FFAA"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0" />
            <TextBlock x:Name="FooterSummaryText"
                       Text="Accounts: 0"
                       Foreground="#FFBDBDBD"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0" />
        </DockPanel>
    </Grid>
</UserControl>

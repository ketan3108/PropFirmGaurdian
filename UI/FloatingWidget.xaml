<UserControl x:Class="PropFirmGuardian.UI.FloatingWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="300"
             Height="140"
             Background="Transparent">
    <Border Background="#E60A0A0F" BorderBrush="#FF2A2A3A" BorderThickness="1" CornerRadius="12" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <DockPanel>
                <Ellipse Width="8" Height="8" Fill="#FF00D4AA" Margin="0,0,8,0" />
                <TextBlock x:Name="AccountText" Text="Guardian" Foreground="White" FontWeight="SemiBold" />
                <TextBlock x:Name="PassText" Text="Pass: 50%" Foreground="#FF00D4AA" HorizontalAlignment="Right" />
            </DockPanel>
            <Grid Grid.Row="1" Margin="0,10,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="PnlText" Text="$0" Foreground="White" FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="P&amp;L" Foreground="#FF8A8A9A" FontSize="10" />
                </StackPanel>
                <Grid Grid.Column="1">
                    <Ellipse Stroke="#FF2A2A3A" StrokeThickness="4" />
                    <TextBlock x:Name="RingText" Text="50%" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
            </Grid>
            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Border Background="#2600D4AA" CornerRadius="10" Padding="8,3" Margin="0,0,6,0">
                    <TextBlock x:Name="SizeText" Text="Size: 100%" Foreground="#FF00D4AA" FontSize="10" />
                </Border>
                <Border Background="#26F59E0B" CornerRadius="10" Padding="8,3">
                    <TextBlock x:Name="GuardText" Text="Clear" Foreground="#FFF59E0B" FontSize="10" />
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
